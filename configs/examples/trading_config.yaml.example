# Hierarchical Trading Configuration (Modular Assembly v2)
# 이 파일은 심볼별 계층적 설정과 모듈 조립식 전략 구성을 보여줍니다.
# 복사해서 configs/trading_config.yaml 로 사용하세요.

trading:
  # 전역 기본값 - 심볼별로 재정의하지 않으면 모든 심볼에 적용됨
  defaults:
    leverage: 1
    max_risk_per_trade: 0.01
    margin_type: ISOLATED
    backfill_limit: 200
    strategy: ict_strategy  # 기본 전략 (모듈 조립의 기반이 됨)
    intervals:
      - 5m
      - 1h
      - 4h

    # [Modular Assembly] 모듈별 기본 구성
    # 각 모듈은 strategy(또는 type)와 params(또는 parameters)로 구성됩니다.
    
    # 1. 진입 결정 모듈 (Entry)
    # ict_optimal_entry, always_entry, sma_entry 중 선택 가능
    entry_config:
      strategy: "ict_optimal_entry"
      params:
        active_profile: "strict"  # strict, balanced, relaxed
        use_killzones: true
        displacement_ratio: 1.5

    # 2. 손절가 결정 모듈 (Stop Loss)
    # zone_based_sl, fixed_percent_sl 중 선택 가능
    stop_loss_config:
      strategy: "zone_based_sl"
      params:
        zone_type: "fvg"          # fvg, order_block, liquidity
        buffer_pips: 5.0

    # 3. 익절가 결정 모듈 (Take Profit)
    # rr_take_profit, displacement_tp 중 선택 가능
    take_profit_config:
      strategy: "rr_take_profit"
      params:
        risk_reward_ratio: 2.0

    # 4. 동적 청산 모듈 (Exit)
    # ict_dynamic_exit, null_exit 중 선택 가능
    exit_config:
      strategy: "ict_dynamic_exit"
      params:
        dynamic_exit_enabled: true
        exit_strategy: "trailing_stop"
        trailing_distance: 0.02
        breakeven_enabled: true

  # 심볼별 설정 - 기본값을 재정의하거나 특정 모듈을 변경함
  symbols:
    # 비트코인 - 보수적인 ICT 전략 조립
    BTCUSDT:
      enabled: true
      leverage: 2
      entry_config:
        params:
          active_profile: "strict"
      stop_loss_config:
        strategy: "zone_based_sl"
        params:
          zone_type: "fvg"

    # 이더리움 - 공격적인 익절과 동적 청산 강화
    ETHUSDT:
      enabled: true
      leverage: 3
      take_profit_config:
        params:
          risk_reward_ratio: 3.0
      exit_config:
        params:
          trailing_distance: 0.015
          breakeven_offset: 0.001

    # 솔라나 - 단순 SMA 진입과 고정 퍼센트 손절 사용 (모듈 교체 예시)
    SOLUSDT:
      enabled: true
      leverage: 5
      entry_config:
        strategy: "sma_entry"
        params:
          period: 20
      stop_loss_config:
        strategy: "fixed_percent_sl"
        params:
          stop_loss_percent: 0.03
      take_profit_config:
        strategy: "rr_take_profit"
        params:
          risk_reward_ratio: 1.5
      exit_config:
        strategy: "null_exit"  # 동적 청산 미사용 (TP/SL에만 의존)

    # 비활성화된 심볼 예시
    XRPUSDT:
      enabled: false

# [참고] 모듈 조립식 설계 (Phase 2)
# 각 심볼의 'modules' 블록을 사용하여 더 명시적으로 구성할 수도 있습니다.
# BTCUSDT:
#   modules:
#     entry: { type: "ict_optimal_entry", params: { ... } }
#     stop_loss: { type: "zone_based_sl", params: { ... } }
#     take_profit: { type: "rr_take_profit", params: { ... } }
#     exit: { type: "ict_dynamic_exit", params: { ... } }
